extends base
include _reviewCard

//- so we can add stuff into the head without overwriting the existing head we do this
block append head
    //- Add Leaflet CSS
    link(rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
            integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
            crossorigin="")
    //- Add Leaflet JS
    //- Make sure you put this AFTER Leaflet's CSS -->
    script(src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin="")

//- when you have repeated code with only a few variables that are different you can create a 'mixin' function and then use that in place of the repeated code. Here we are doing it for the details like date, difficulty etc. To place it in the document you simply use the + sign in front of it's name
mixin overviewBox(icon, label, text)
    .overview-box__detail
        svg.overview-box__icon
            use(xlink:href=`/img/icons.svg#icon-${icon}`)
        span.overview-box__label= label
        span.overview-box__text= text

block content
    section.section-header
        .header__hero
            .header__hero-overlay &nbsp;
            img.header__hero-img(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)

            .heading-box
                h1.heading-primary
                    span=`${tour.name} Tour`
                .heading-box__group
                    .heading-box__detail
                        svg.heading-box__icon
                            use(xlink:href='/img/icons.svg#icon-clock')
                        span.heading-box__text=`${tour.duration} days`
                    .heading-box__detail
                        svg.heading-box__icon
                            use(xlink:href='/img/icons.svg#icon-map-pin')
                        span.heading-box__text=`${tour.startLocation.description}`

    section.section-description
        .overview-box
            div
                .overview-box__group
                    h2.heading-secondary.ma-bt-lg Quick facts
                    //- using the mixin we created at the top of the page
                    +overviewBox('calendar','Next date',new Date(tour.startDates[0]).toLocaleString('en-gb', {month: 'long', year: 'numeric'}))

                    +overviewBox('trending-up', 'Difficulty', tour.difficulty)

                    +overviewBox('user', 'Participants', tour.maxGroupSize)

                    +overviewBox('star', 'Rating', `${tour.ratingsAverage} / 5`)

                .overview-box__group
                    h2.heading-secondary.ma-bt-lg Your tour guides
                    each guide in tour.guides
                        .overview-box__detail
                            img.overview-box__img(src=`/img/users/${guide.photo}`, alt=`${guide.name}`)
                            //- let's use some raw javascript for the conditional that gives us the label
                            - const guideLabel = guide.role.toLowerCase() === 'lead-guide' ? 'Lead Guide' : 'Tour Guide'
                            span.overview-box__label= guideLabel
                            span.overview-box__text=guide.name

        .description-box
            h2.heading-secondary.ma-bt-lg= `About the ${tour.name} tour`
            - const descriptionParas = tour.description.split('\n')
            each para in descriptionParas
                p.description__text= para

    section.section-pictures
        //- to be able to access the index in an 'each loop' we can simply define the second parameter. We come across a problem with the number that appears in the class name though, but the workaround is simply to add it via the 'class' attribute as though it were a normal img element
        each img, i in tour.images
            .picture-box
                img.picture-box__img(src=`/img/tours/${img}`, alt=`${tour.name} ${i + 1}`, class=`picture-box__img--${i + 1}`)

    section.section-map
        //- to be able to access the locations data in our tourMap.js file we can add it as a data attribute to the element that will contain the map. We have to stringify it first and then parse it in the tourMap.js file
        #map(data-start-location=JSON.stringify(tour.startLocation), data-locations=JSON.stringify(tour.locations))
    

    section.section-reviews
        .reviews
            each review in tour.reviews
                +reviewCard(review)

    section.section-cta
        .cta
            .cta__img.cta__img--logo
                img(src='/img/logo-white.png', alt='Natours logo')
            img.cta__img.cta__img--1(src=`/img/tours/${tour.images[0]}`, alt='Tour Image 1')
            img.cta__img.cta__img--2(src=`/img/tours/${tour.images[1]}`, alt='Tour Image 2')
            .cta__content
                h2.heading-secondary What are you waiting for?
                p.cta__text= `${tour.duration} days. 1 adventure. Infinite memories. Make it yours today!`
                button.btn.btn--green.span-all-rows Book tour now!
                //- button.btn.btn--green Book tour now!
    //- we need the map dom to have loaded before we run this script so we put it at the end of the body and not in the head    
    script(src='/js/tourMap.js')