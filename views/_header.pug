//- to define the class of an element you simply join it with a . sign, if there is more than one then simply chain them with . eg class='nav nav--tours' in the nav element becomes nav.nav.nav--tours
header.header
    nav.nav.nav--tours
        a.nav__el(href='/') All Tours
    //- when it's a div element you don't need to write div you simply start with a .
    .header__logo
        img(src="/img/logo-white.png" alt="Natours logo")
    nav.nav.nav--user
        //- in our auth controller we have added the middleware to add user to the res.locals object so we can use that here
        if user
            a.nav__el.nav__el--logout Log out
            a.nav__el(href='#')
                img.nav__user-img(src=`/img/users/${user.photo || 'default.jpg'}` alt=`photo of ${user.name}`)
                span= user.name.split(' ')[0]
        else
            unless currentPath === '/login'
                a.nav__el(href='/login') Log In
            unless currentPath === '/signup'
                a.nav__el.nav__el--cta(href='/signup') Sign Up
        