extends base

block content
    main.main
        .login-form
            h2.heading-secondary.ma-bt-lg Sign up for Natours
            form.form
            .form__group
                label.form__label(for='email') Full Name
                input#name.form__input(type='text', placeholder='Full Name', required, autocomplete='name', autofocus)
            .form__group
                label.form__label(for='email') Email address
                input#email.form__input(type='email', placeholder='you@example.com', required, autocomplete='email')
            .form__group
                label.form__label(for='password') Password (min. 8 characters)
                input#password.form__input(type='password', placeholder='••••••••', required, autocomplete='new-password', minlength='8')
            .form__group.ma-bt-md
                label.form__label(for='confirm-password') Confirm Password
                input#confirm-password.form__input(type='password', placeholder='••••••••', required, autocomplete='new-password', minlength='8')
            .form__group
                button.btn.btn--green Sign Up