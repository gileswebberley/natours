doctype html
html
    //- by adding a block to the head and using 'block append' in the child files (for our tour map first) we can add content to the head of the document without overwriting this head
    head
        block head
            meta(charset='UTF-8')
            meta(name="viewport" content="width=device-width, initial-scale=1.0")
            //- even though the title local variable is set in the render of 'overview' and 'tour' we still have access to it here because those two pages 'extends' this base file
            title Natours | #{title}
            link(href="https://fonts.googleapis.com/css?family=Lato:300,300i,700"
        rel="stylesheet")
            link(rel='stylesheet' href='/css/style.css')
            link(rel='shortcut icon' type='image/png' href='/img/favicon.png')
            //- universal logout functionality which is deferred until the dom loads and also doesn't add a listener if there is no logout button currently in the _header
            script(type='module' src='/js/logout.js')
            
    body
        // HEADER
        //- to add the header from a seperate file you can simply use the include keyword and the name of the pug file - this is like the opposite of the way we use 'block'
        include _header
        // CONTENT
        block content
        // FOOTER
        include _footer