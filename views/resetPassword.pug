extends base
//- get our show/hide password field mixin
include _passwordInput

block append head
    script(src='/js/passwordInputToggler.js')
    script(type='module' src='/js/resetPassword.js' defer)

block content
    main.main
        .login-form
            h2.heading-secondary.ma-bt-lg Create New Password
            form.form
                input#token(type='hidden' value=`${token}`)
                .form__group
                    +passwordInput('password', 'password', 'Password (min. 8 characters)')(placeholder='••••••••' autocomplete='new-password' minlength='8')
                    //- label.form__label(for='password') Password (min. 8 characters)
                    //- input#password.form__input(type='password', placeholder='••••••••', required, autocomplete='new-password', minlength='8')
                .form__group.ma-bt-md
                    +passwordInput('confirmPassword', 'password', 'Confirm Password')(placeholder='••••••••' autocomplete='new-password' minlength='8')
                    //- label.form__label(for='confirm-password') Confirm Password
                    //- input#confirm-password.form__input(type='password', placeholder='••••••••', required, autocomplete='new-password', minlength='8')
                .form__group
                    button.btn.btn--green Set Password